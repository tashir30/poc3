# Min 32 characters — generate with: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend: sqlite (localhost POC) | supabase (Vercel production)
ELEVO_BACKEND=sqlite

# --- SQLite (localhost, default) ---
DATABASE_PATH=./data/poc3.db

# --- Supabase (production / Vercel) ---
# ELEVO_BACKEND=supabase
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# DATABASE_URL=postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:6543/postgres

# Localhost dev only: enables console OTP + dev billing bypass
ELEVO_DEV_AUTH=true
NEXT_PUBLIC_ELEVO_DEV_AUTH=true

# Comma-separated merchant phones promoted to platform admin
ELEVO_PLATFORM_ADMIN_PHONES=

# Optional: SMS webhook URL for production OTP delivery
# ELEVO_SMS_WEBHOOK_URL=

# Optional Razorpay (production billing)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# Mobile testing from LAN (comma-separated IPs)
# ALLOWED_DEV_ORIGINS=192.168.1.10
